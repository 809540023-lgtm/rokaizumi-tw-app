###############################################
# rokaizumi-tw v4 . 完整環境變數範本
# 部署到任何平台前先把這些設好
###############################################

# === 必填 ===

# 應用程式環境
NODE_ENV=production
PORT=3000

# 資料庫（MySQL 8）
# 例：mysql://user:pass@host:3306/dbname
DATABASE_URL=mysql://rokaizumi:CHANGE_ME@localhost:3306/rokaizumi

# JWT 簽章密鑰（32 字以上隨機字串）
# 產生：openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING_AT_LEAST_32_CHARS

# === 金流（Stripe） ===
# 申請：https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# === 圖片儲存（AWS S3 或相容服務） ===
# 也可改用 Cloudflare R2、Backblaze B2 等 S3 相容服務
S3_BUCKET=rokaizumi-products
S3_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 自訂 endpoint（用 R2 等服務時）
# S3_ENDPOINT=https://accountid.r2.cloudflarestorage.com

# === Email 服務（Newsletter / 訂單通知）===
# Resend 推薦：https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=service@rokaizumi-tw.jp

# === 選用：Telegram Bot（接訂單 / 詢價通知）===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === 選用：LLM AI 客服 ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === 選用：分析追蹤 ===
GA_MEASUREMENT_ID=G-XXXXXXXXXX
FACEBOOK_PIXEL_ID=

# === Docker Compose 專用（用 docker-compose 時才需要） ===
DB_ROOT_PASSWORD=CHANGE_ME
DB_PASSWORD=CHANGE_ME
